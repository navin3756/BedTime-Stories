# OLLAMA_URL: Local Ollama server used for story generation.
# Install Ollama and pull a model, for example:
#   ollama pull llama3.2:1b
OLLAMA_URL="http://127.0.0.1:11434"

# OLLAMA_MODEL: Optional. Leave blank to use the first installed Ollama model.
OLLAMA_MODEL=""

# ELEVENLABS_API_KEY: Optional. Enables private family voice cloning and cloned story narration
# through the Vercel server-side API routes. Do not expose this in client-side code.
ELEVENLABS_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
